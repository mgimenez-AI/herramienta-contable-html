# Configuracion simple para usar GitHub como almacenamiento compartido.
#
# La app funciona en GitHub Pages y guarda los datos en:
# data/app-data.json
#
# Para leer datos de un repo publico no hace falta token.
# Para guardar cambios desde la app, GitHub exige un token con permiso:
# Contents: Read and write.
#
# Opcion recomendada para demo:
# - dejar VITE_GITHUB_TOKEN vacio;
# - cuando la app pida el token en el navegador, pegarlo una vez.

VITE_DATA_BACKEND=github
VITE_GITHUB_OWNER=mgimenez-AI
VITE_GITHUB_REPO=herramienta-contable-html
VITE_GITHUB_BRANCH=main
VITE_GITHUB_DATA_PATH=data/app-data.json

# Opcional. No recomendado para proyectos reales porque queda visible en el navegador.
# Para datos ficticios puede usarse si se acepta ese riesgo.
VITE_GITHUB_TOKEN=
