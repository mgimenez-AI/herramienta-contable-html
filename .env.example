# Copiá este archivo a ".env" y completá los valores.
# Ver SETUP.md para el paso a paso completo (registro en Entra ID + Listas de SharePoint).
#
# Si dejás estas variables vacías, la app corre en "modo local": guarda los datos
# solo en este navegador (localStorage), sin login ni SharePoint. Útil para probar
# la interfaz mientras se gestiona el acceso con IT.

# ---- Entra ID (Azure AD) — registro de la aplicación ----
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# URL exacta donde quede alojada la app (debe coincidir con el Redirect URI
# configurado en Entra ID). Si se deja vacío, se usa el origin actual del navegador.
VITE_AZURE_REDIRECT_URI=

# ---- Sitio de SharePoint ----
# Hostname del tenant, ej: contoso.sharepoint.com
VITE_SP_SITE_HOSTNAME=
# Ruta del sitio, ej: /sites/ContabilidadImpuestos
VITE_SP_SITE_PATH=

# ---- Nombres de las Listas (dejar por defecto si no los cambiaste) ----
VITE_SP_LIST_TAREAS=Tareas
VITE_SP_LIST_EQUIPO=Equipo
VITE_SP_LIST_PROYECTOS=Proyectos
